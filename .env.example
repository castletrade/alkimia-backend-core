# Castle Trade LLC - Alkimia Backend Infrastructure Configuration
# Institutional Environment Template

# DATABASE CONFIGURATION
# High-availability PostgreSQL cluster URL
DB_URL=postgresql://user:password@hostname:5432/dbname

# STRIPE CONNECT CONFIGURATION
# Institutional API credentials (Live/Test)
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# SUPABASE AUTHENTICATION
# Federated identity provider endpoints
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

# REDIS CACHE LAYER
# Distributed state and session management
REDIS_URL=redis://default:password@hostname:6379/0

# SRE OBSERVABILITY
# OpenTelemetry and Sentry configurations
LOG_LEVEL=INFO
SENTRY_DSN=https://...
PROMETHEUS_ENDPOINT=...

# SYSTEM IDENTIFIERS
DEPLOYMENT_ENVIRONMENT=production
REGION=us-east-1
